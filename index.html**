<!-- This is the homepage. Include: Hero section with compelling headline, Call-to-action buttons, Features/benefits section, Testimonials (if applicable), Footer with links and info -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brew and Haven</title>
    <link rel="stylesheet" href="css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <h1>Welcome to Brew and Haven</h1>
            <p>Experience the perfect blend of coffee and comfort</p>
            <div class="cta-btns">
                <button class="btn btn-primary">Learn More</button>
                <button class="btn btn-secondary">Get Started</button>
            </div>
        </div>
    </section>

    <!-- Features/Benefits Section -->
    <section class="features">
        <div class="container">
            <h2>What We Offer</h2>
            <div class="feature-grid">
                <div class="feature">
                    <i class="fas fa-coffee"></i>
                    <h3>High-Quality Coffee</h3>
                    <p>Our coffee is sourced from the finest beans and roasted to perfection</p>
                </div>
                <div class="feature">
                    <i class="fas fa-home"></i>
                    <h3>Cozy Atmosphere</h3>
                    <p>Our cafes are designed to make you feel at home</p>
                </div>
                <div class="feature">
                    <i class="fas fa-wifi"></i>
                    <h3>Fast and Reliable Wi-Fi</h3>
                    <p>Stay connected while you enjoy your coffee</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials Section -->
    <section class="testimonials">
        <div class="container">
            <h2>What Our Customers Say</h2>
            <div class="testimonial-grid">
                <div class="testimonial">
                    <p>"Brew and Haven is my go-to coffee spot. The coffee is always delicious and the staff is friendly."</p>
                    <span>— John Doe</span>
                </div>
                <div class="testimonial">
                    <p>"I love the cozy atmosphere of Brew and Haven. It's the perfect place to study or work."</p>
                    <span>— Jane Smith</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer Section -->
    <footer>
        <div class="container">
            <div class="footer-grid">
                <div class="footer-col">
                    <h3>About Us</h3>
                    <p>We're a team of coffee lovers dedicated to providing the best coffee experience.</p>
                </div>
                <div class="footer-col">
                    <h3>Get in Touch</h3>
                    <ul>
                        <li><a href="#">Contact Us</a></li>
                        <li><a href="#">FAQs</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h3>Follow Us</h3>
                    <ul>
                        <li><a href="#"><i class="fab fa-facebook"></i></a></li>
                        <li><a href="#"><i class="fab fa-instagram"></i></a></li>
                        <li><a href="#"><i class="fab fa-twitter"></i></a></li>
                    </ul>
                </div>
            </div>
            <p>&copy; 2023 Brew and Haven. All rights reserved.</p>
        </div>
    </footer>

    <script src="js/script.js"></script>
</body>
</html>